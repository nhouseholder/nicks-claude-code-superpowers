{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/kimi-k2.6",
  "mcp": {
    "brain-router": {
      "type": "local",
      "command": [
        "brain-router"
      ],
      "environment": {
        "BRAIN_PROJECT": "global",
        "ENGRAM_DB": "{env:HOME}/.engram/engram.db",
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true
    },
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "environment": {
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "prompt_file": "agents/generated/orchestrator.md"
    },
    "explorer": {
      "mode": "all",
      "prompt_file": "agents/generated/explorer.md"
    },
    "strategist": {
      "mode": "all",
      "prompt_file": "agents/generated/strategist.md"
    },
    "researcher": {
      "mode": "all",
      "prompt_file": "agents/generated/researcher.md"
    },
    "designer": {
      "mode": "all",
      "prompt_file": "agents/generated/designer.md"
    },
    "auditor": {
      "mode": "all",
      "prompt_file": "agents/generated/auditor.md"
    },
    "council": {
      "mode": "subagent",
      "prompt_file": "agents/generated/council.md",
      "note": "Protocol reference only. Councillors inherit the active orchestrator/session model unless you add explicit agent-level overrides."
    },
    "council-advocate-for": {
      "mode": "subagent",
      "model": "openrouter/openai/gpt-oss-120b:free",
      "prompt_file": "agents/generated/council-advocate-for.md"
    },
    "council-advocate-against": {
      "mode": "subagent",
      "model": "openrouter/xiaomi/mimo-v2-flash:free",
      "prompt_file": "agents/generated/council-advocate-against.md"
    },
    "council-judge": {
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3-235b-a22b-thinking-2507:free",
      "prompt_file": "agents/generated/council-judge.md"
    },
    "generalist": {
      "mode": "all",
      "prompt_file": "agents/generated/generalist.md"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  }
}
