{
  "env": {
    "API_TIMEOUT_MS": "120000"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Edit",
      "Read",
      "Glob",
      "Grep",
      "Task",
      "Agent",
      "TodoWrite",
      "Skill",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "mcp__Desktop_Commander__*",
      "mcp__Claude_in_Chrome__*",
      "mcp__PDF_Tools_-_Fill__Analyze__Extract__View__*",
      "mcp__Claude_Preview__*"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "~/.claude"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/session-init-guard.py",
            "timeout": 1000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/ufc-context-loader.py",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/memory-consolidate-loader.py",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/session-context-loader.py",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/anti-pattern-enforcer.py",
            "timeout": 2000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/plan-mode-enforcer.py",
            "timeout": 1000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/token-advisor.py",
            "timeout": 1000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/improve-prompt.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/correction-detector.py",
            "timeout": 2000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/context-saver.py",
            "timeout": 1000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/project-domain-guard.py",
            "timeout": 1000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/plan-execution-guard.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nicholashouseholder/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/bash-guard.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/protect-skills.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/agent-limit.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/mmalogic-site-guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/anti-pattern-gate.py",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/plan-mode-enforcer.py",
            "timeout": 2000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/unpushed-commits-check.py",
            "timeout": 15000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/no-narration-stops.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/session-complete-notify.py",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/memory-consolidate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/observe.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/surgical-scope.py"
          }
        ]
      },
      {
        "matcher": "Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/impossible-stats-detector.py"
          }
        ]
      },
      {
        "matcher": "Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/python3 ~/.claude/hooks/missing-odds-detector.py"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {},
  "enabledMcpjsonServers": [
    "youtube-transcript"
  ]
}